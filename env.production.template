# Production Environment Variables for Local Server Deployment
# Copy this file to .env and update with your actual values

# ============================================
# Environment Configuration
# ============================================
ENVIRONMENT=production
DEBUG=false

# ============================================
# Security - CRITICAL: Change these values!
# ============================================
# Generate a secure secret key (minimum 32 characters)
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARS

# JWT Settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# Database Configuration
# ============================================
# MongoDB connection string
# For local deployment, use: mongodb://mongodb:27017
# For external MongoDB, use: mongodb://user:password@host:port/database
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DATABASE=hh_analyzer

# ============================================
# Redis Configuration
# ============================================
# Redis connection string
# For local deployment, use: redis://redis:6379
# For external Redis with password: redis://:password@host:port
REDIS_URL=redis://redis:6379

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
# For local network deployment, include:
# - Server IP address (e.g., http://192.168.1.100)
# - Server hostname (e.g., http://server.company.local)
# - Localhost for testing (http://localhost)
# Example: CORS_ORIGINS=http://192.168.1.100,http://server.company.local,http://localhost
CORS_ORIGINS=http://localhost,http://127.0.0.1

# ============================================
# AI Service Configuration
# ============================================
# Cloudflare Worker URL for Gemini API
CLOUDFLARE_WORKER_URL=https://proud-water-5293.olegvagin1311.workers.dev

# Optional: Direct Gemini API key (if not using Cloudflare Worker)
# GEMINI_API_KEY=

# Hugging Face Inference API (recommended fallback)
# Get token from: https://huggingface.co/settings/tokens
# Select: "Make calls to Inference Providers" permission
HUGGING_FACE_API_TOKEN=
HUGGING_FACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Ollama (optional, local AI models)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=mistral

# ============================================
# HeadHunter API Configuration (Optional)
# ============================================
# If you need HeadHunter OAuth integration
# HH_CLIENT_ID=
# HH_CLIENT_SECRET=
# HH_REDIRECT_URI=http://your-server-ip/auth/callback

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json
# Optional: Log file path (leave empty for console only)
# LOG_FILE=/app/logs/app.log

# ============================================
# AI Analysis Settings
# ============================================
MAX_RESUMES_FOR_DEEP_ANALYSIS=50
MAX_RESUMES_FROM_SEARCH=200
